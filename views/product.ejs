<%- include('partials/header', { title: product.name + ' — Glow Scents', user: user }) %>

<div style="padding-top:68px;"></div>

<div class="container" style="padding:60px 24px;">
  <!-- Breadcrumb -->
  <nav style="font-size:13px;color:var(--muted);margin-bottom:32px;">
    <a href="/">Home</a> <span style="margin:0 8px;">›</span>
    <a href="/catalog">Catalog</a> <span style="margin:0 8px;">›</span>
    <a href="/catalog?cat=<%= product.category %>"><%= product.category === 'oil' ? 'Oil Perfumes' : 'Miniatures' %></a>
    <span style="margin:0 8px;">›</span> <span style="color:var(--text)"><%= product.name %></span>
  </nav>

  <div class="product-detail-grid">
    <!-- Image Panel -->
    <div class="detail-image-panel">
      <% if (product.badge) { %>
        <span class="product-badge" style="position:absolute;top:20px;left:20px;font-size:12px;padding:6px 14px;">
          <%= product.badge %>
        </span>
      <% } %>
      <div class="detail-icon"><%= product.category === 'miniature' ? '🧪' : '🧴' %></div>
      <div class="detail-glow"></div>
    </div>

    <!-- Info Panel -->
    <div class="detail-info">
      <p class="product-category" style="font-size:12px;letter-spacing:2px;text-transform:uppercase;color:var(--muted);margin-bottom:10px;">
        <%= product.category === 'oil' ? 'Oil Perfume' : 'Miniature' %>
      </p>
      <h1 style="font-family:'Cormorant Garamond',serif;font-size:clamp(32px,4vw,48px);color:var(--text);margin-bottom:8px;"><%= product.name %></h1>
      <p style="font-size:12px;color:var(--muted);letter-spacing:2px;margin-bottom:20px;">SIZE: <%= product.size %></p>
      <p style="font-size:15px;color:var(--muted);line-height:1.8;margin-bottom:28px;"><%= product.description %></p>

      <!-- Price -->
      <div style="display:flex;align-items:baseline;gap:12px;margin-bottom:28px;">
        <span style="font-family:'Cormorant Garamond',serif;font-size:36px;font-weight:600;color:var(--gold);">₦<%= product.price.toLocaleString() %></span>
        <% if (product.stock < 20) { %>
          <span style="font-size:12px;color:#c0392b;letter-spacing:1px;">Only <%= product.stock %> left</span>
        <% } else { %>
          <span style="font-size:12px;color:#27ae60;letter-spacing:1px;">✓ In Stock</span>
        <% } %>
      </div>

      <!-- Notes -->
      <div style="margin-bottom:28px;">
        <p style="font-size:11px;letter-spacing:2px;text-transform:uppercase;color:var(--muted);margin-bottom:12px;">Fragrance Notes</p>
        <div style="display:flex;flex-direction:column;gap:8px;">
          <div><span style="font-size:11px;color:var(--gold);letter-spacing:1px;text-transform:uppercase;margin-right:8px;">Top</span>
            <% product.notes.top.split(',').forEach(n => { %><span class="note-tag"><%= n.trim() %></span><% }) %>
          </div>
          <div><span style="font-size:11px;color:var(--gold);letter-spacing:1px;text-transform:uppercase;margin-right:8px;">Mid</span>
            <% product.notes.mid.split(',').forEach(n => { %><span class="note-tag"><%= n.trim() %></span><% }) %>
          </div>
          <div><span style="font-size:11px;color:var(--gold);letter-spacing:1px;text-transform:uppercase;margin-right:8px;">Base</span>
            <% product.notes.base.split(',').forEach(n => { %><span class="note-tag"><%= n.trim() %></span><% }) %>
          </div>
        </div>
      </div>

      <!-- Add to Cart -->
      <div style="display:flex;gap:12px;flex-wrap:wrap;">
        <div style="display:flex;align-items:center;gap:10px;background:var(--white);border:1.5px solid var(--cream-dark);border-radius:var(--radius);padding:6px 14px;">
          <button onclick="changeQty(-1)" class="qty-btn">−</button>
          <span class="qty-num" id="qty-display">1</span>
          <button onclick="changeQty(1)" class="qty-btn">+</button>
        </div>
        <button class="btn btn-gold" style="flex:1;" onclick="addProductToCart()">🛍️ Add to Cart</button>
      </div>

      <div id="added-msg" style="display:none;" class="alert alert-success" style="margin-top:16px;">
        ✓ Added to cart! <a href="/cart">View cart →</a>
      </div>

      <div style="display:flex;gap:20px;margin-top:24px;font-size:13px;color:var(--muted);">
        <span>✦ Pure oil formula</span>
        <span>✦ Long lasting</span>
        <span>✦ Alcohol free</span>
      </div>
    </div>
  </div>

  <!-- Related Products -->
  <% if (related.length > 0) { %>
  <div style="margin-top:80px;">
    <p class="section-sub">More from our collection</p>
    <h2 class="section-title" style="margin-bottom:32px;">You May Also Like</h2>
    <div class="product-grid">
      <% related.forEach(function(p) { %>
        <%- include('partials/product-card', { product: p }) %>
      <% }) %>
    </div>
  </div>
  <% } %>
</div>

<style>
.product-detail-grid { display:grid;grid-template-columns:1fr 1fr;gap:60px;align-items:start; }
.detail-image-panel {
  position:relative;border-radius:var(--radius-lg);overflow:hidden;
  background:linear-gradient(135deg,var(--ebony),var(--dark-brown),#5a2800);
  height:520px;display:flex;align-items:center;justify-content:center;
}
.detail-icon { font-size:140px;filter:drop-shadow(0 8px 32px rgba(212,168,67,0.4));position:relative;z-index:1; }
.detail-glow { position:absolute;width:300px;height:300px;border-radius:50%;background:radial-gradient(circle,rgba(212,168,67,0.15),transparent 70%);top:50%;left:50%;transform:translate(-50%,-50%); }
@media(max-width:800px){
  .product-detail-grid { grid-template-columns:1fr; }
  .detail-image-panel { height:300px; }
}
</style>

<script>
let qty = 1;
function changeQty(d) {
  qty = Math.max(1, qty + d);
  document.getElementById('qty-display').textContent = qty;
}
function addProductToCart() {
  const product = <%- JSON.stringify(product) %>;
  for (let i = 0; i < qty; i++) addToCart(product);
  document.getElementById('added-msg').style.display = 'block';
  setTimeout(() => document.getElementById('added-msg').style.display = 'none', 3000);
}
</script>

<%- include('partials/footer') %>
