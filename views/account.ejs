<%- include('partials/header', { title: 'My Account — Glow Scents', user: user }) %>

<div class="page-header">
  <div class="container">
    <h1>My Account</h1>
    <p>Update your profile and delivery details</p>
  </div>
</div>

<section style="padding:60px 0 100px;">
  <div class="container" style="max-width:640px;">
    <% if (success) { %><div class="alert alert-success">✓ Profile updated successfully!</div><% } %>

    <div style="background:var(--white);border-radius:var(--radius-lg);padding:36px;box-shadow:var(--shadow);">
      <h2 style="font-family:'Cormorant Garamond',serif;font-size:24px;margin-bottom:24px;">Profile Details</h2>

      <form method="POST" action="/account">
        <div class="form-group">
          <label class="form-label">Full Name</label>
          <input type="text" name="name" class="form-input" value="<%= userData.name || '' %>" required>
        </div>

        <div class="form-group">
          <label class="form-label">Email Address</label>
          <input type="email" class="form-input" value="<%= userData.email || '' %>" disabled style="opacity:0.6;cursor:not-allowed;">
          <p style="font-size:12px;color:var(--muted);margin-top:4px;">Email cannot be changed</p>
        </div>

        <div class="form-group">
          <label class="form-label">Phone Number</label>
          <input type="tel" name="phone" class="form-input" value="<%= userData.phone || '' %>" required>
        </div>

        <div class="form-group">
          <label class="form-label">Default Delivery Address</label>
          <input type="text" name="address" class="form-input" value="<%= userData.address || '' %>" required>
        </div>

        <div class="form-row">
          <div class="form-group">
            <label class="form-label">City</label>
            <input type="text" name="city" class="form-input" value="<%= userData.city || '' %>" required>
          </div>
          <div class="form-group">
            <label class="form-label">State</label>
            <input type="text" name="state" class="form-input" value="<%= userData.state || '' %>">
          </div>
        </div>

        <button type="submit" class="btn btn-gold">Save Changes</button>
      </form>
    </div>

    <div style="display:flex;gap:12px;margin-top:20px;flex-wrap:wrap;">
      <a href="/my-orders" class="btn btn-outline">View My Orders</a>
      <a href="/logout" class="btn btn-dark">Log Out</a>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
