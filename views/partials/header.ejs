<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🧴</text></svg>">
</head>
<body>

<nav id="navbar">
  <a href="/" class="nav-brand">Glow <span>Scents</span></a>
  <div class="nav-links">
    <a href="/" <%= typeof currentPage !== 'undefined' && currentPage === 'home' ? 'class="active"' : '' %>>Home</a>
    <a href="/catalog">Catalog</a>
    <a href="/catalog?cat=oil">Oil Perfumes</a>
    <a href="/catalog?cat=miniature">Miniatures</a>
    <% if (user) { %>
      <a href="/my-orders">My Orders</a>
      <a href="/account" class="nav-user">👤 <%= user.split(' ')[0] %></a>
      <a href="/cart" class="nav-cart">🛍️ Cart <span class="cart-count" id="nav-cart-count">0</span></a>
      <a href="/logout" style="font-size:11px;color:var(--muted);">Logout</a>
    <% } else { %>
      <a href="/login">Log In</a>
      <a href="/register" class="btn btn-gold btn-sm">Register</a>
    <% } %>
  </div>
  <div class="hamburger" onclick="toggleMenu()" id="hamburger">
    <span></span><span></span><span></span>
  </div>
</nav>

<!-- Mobile Menu -->
<div class="mobile-menu" id="mobileMenu">
  <a href="/" onclick="closeMenu()">Home</a>
  <a href="/catalog" onclick="closeMenu()">Catalog</a>
  <a href="/catalog?cat=oil" onclick="closeMenu()">Oil Perfumes</a>
  <a href="/catalog?cat=miniature" onclick="closeMenu()">Miniatures</a>
  <% if (user) { %>
    <a href="/my-orders" onclick="closeMenu()">My Orders</a>
    <a href="/cart" onclick="closeMenu()">🛍️ Cart</a>
    <a href="/account" onclick="closeMenu()">My Account</a>
    <a href="/logout">Logout</a>
  <% } else { %>
    <a href="/login" onclick="closeMenu()">Log In</a>
    <a href="/register" onclick="closeMenu()">Register</a>
  <% } %>
</div>

<script>
function toggleMenu() {
  document.getElementById('mobileMenu').classList.toggle('open');
}
function closeMenu() {
  document.getElementById('mobileMenu').classList.remove('open');
}
// Update cart count from localStorage
function updateCartBadge() {
  const cartEl = document.getElementById('nav-cart-count');
  if (!cartEl) return;
  try {
    const cart = JSON.parse(localStorage.getItem('glow_scents_cart') || '[]');
    const count = cart.reduce((s,i) => s + i.qty, 0);
    cartEl.textContent = count;
    cartEl.style.display = count > 0 ? 'flex' : 'flex';
  } catch(e) {}
}
updateCartBadge();
</script>
