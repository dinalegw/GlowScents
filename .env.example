# Glow Scents Environment Variables

# Where order and contact emails are sent
OWNER_EMAIL=owner@example.com

# SMTP configuration for sending email notifications
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your.email@gmail.com
SMTP_PASS=your-gmail-app-password

# WhatsApp contact number in international format (optional)
WA_NUMBER=+2348000000000

# Session secret for express-session
SESSION_SECRET=change_this_to_a_strong_random_string
